NODE_ENV=development
# Neon PostgreSQL connection string format
DATABASE_URL=postgres://[user]:[password]@[hostname]/[database]?sslmode=require
# Example: postgresql://alex:pass123@ep-cool-snow-123456.us-east-2.aws.neon.tech/neondb?sslmode=require
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=http://localhost:3000